# Optional overrides for local terraform plan/apply.
# CI passes -var="image_tag=$GITHUB_SHA" on deploy.

# image_tag = "local-dev"

# Slim API defaults (variables.tf): api_cpu=1024, api_memory=2048
# Whisper-era was 1024/4096; 512/2048 failed ALB health during Jul 2026 cutover.
# api_cpu    = 1024
# api_memory = 2048
# ui_cpu     = 256
# ui_memory  = 512

# Stage B (default): no public IPs; VPC endpoints required.
# Rollback to Stage A if ECR pulls fail:
# enable_no_egress_networking = false
# enable_vpc_endpoints = true
