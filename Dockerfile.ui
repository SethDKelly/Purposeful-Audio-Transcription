# RRE Streamlit UI — HTTP client of the API (RRE_API_BASE_URL / BACKEND_API_URL).
# Do not import backend.services / repositories / db from ui/ (see docs/developer/ui-api-boundary.md).
FROM python:3.12-slim-bookworm

RUN apt-get update \
    && apt-get install -y --no-install-recommends curl \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY pyproject.toml README.md ./
COPY backend ./backend
COPY config ./config
COPY ui ./ui

# UI does not need Whisper/torch — core + Streamlit only.
RUN pip install --no-cache-dir --upgrade pip \
    && pip install --no-cache-dir -e ".[ui]"

ENV STREAMLIT_SERVER_PORT=8501 \
    STREAMLIT_SERVER_ADDRESS=0.0.0.0 \
    STREAMLIT_SERVER_HEADLESS=true \
    STREAMLIT_BROWSER_GATHER_USAGE_STATS=false

EXPOSE 8501

HEALTHCHECK --interval=30s --timeout=5s --start-period=120s --retries=5 \
    CMD curl -f "http://127.0.0.1:8501/_stcore/health" || exit 1

CMD ["streamlit", "run", "ui/streamlit_app.py", "--server.address=0.0.0.0", "--server.port=8501"]
