# Tooling / pytest only — not a supported local product server.
# Runtime configuration for the app lives in ECS task defs (infra/dev).

LLM_PROVIDER=bedrock
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-5-20250929-v1:0
TRANSCRIPTION_PROVIDER=transcribe
# UPLOADS_BUCKET=  # required on AWS for Transcribe
# TRANSCRIBE_LANGUAGE=en-US
# TRANSCRIBE_TIMEOUT_SECONDS=3600
# TRANSCRIBE_POLL_SECONDS=5
# BEDROCK_MAX_TOKENS=8192
# BEDROCK_PROMPT_CACHE=true
# BEDROCK_PROMPT_CACHE_TTL=1h
# AWS_REGION=us-east-2

MAX_UPLOAD_MB=100
TEMP_DIR=./data/temp
LOG_LEVEL=INFO
API_HOST=127.0.0.1
API_PORT=8000
RRE_API_BASE_URL=
STREAMLIT_PORT=8501

DATABASE_URL=sqlite:///./data/rre.db
DATABASE_POOL_SIZE=5
ALEMBIC_AUTO_UPGRADE=false
# Optional API auth for local pytest / tooling against a secured API.
# On AWS, ECS injects API_KEY for both API and UI from Secrets Manager.
API_KEY=
LOG_JSON=false
# LOG_REDACT=true
# TRANSCRIPT_RETENTION_DAYS=90
WORKFLOW_BACKGROUND_DEFAULT=false
WORKFLOW_SYNC_MODULE_LIMIT=6
# Parallel transcript modules on Postgres/AWS (SQLite forces 1). Meta stays sequential.
WORKFLOW_MODULE_CONCURRENCY=3
EVIDENCE_PROMPT_MAX_QUOTES=120
EVIDENCE_PROMPT_HEAD_QUOTES=80
EVIDENCE_PROMPT_TAIL_QUOTES=40
