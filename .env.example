OLLAMA_HOST=http://localhost:11434
WHISPER_MODEL=base
WHISPER_DEVICE=auto
WHISPER_COMPUTE_TYPE=int8
DIARIZATION_ENABLED=true
DIARIZATION_MODEL=pyannote/speaker-diarization-3.1
DIARIZATION_DEVICE=auto
DIARIZATION_SPEAKER_PREFIX=Person
# Drop turns shorter than this (seconds); set 0 to disable.
DIARIZATION_MIN_DURATION_ON=0.3
# Merge same-speaker gaps shorter than this (seconds); set 0 to disable.
DIARIZATION_MIN_DURATION_OFF=0.2
# overlap = Whisper first + align; sliced = diarize then transcribe per speaker interval.
TRANSCRIPTION_MODE=sliced
# whisper (local) | transcribe (Amazon Transcribe on AWS)
TRANSCRIPTION_PROVIDER=whisper
# TRANSCRIBE_LANGUAGE=en-US
# UPLOADS_BUCKET=
WHISPER_MIN_SLICE_DURATION=0.5
WHISPER_BATCH_SIZE=8
WHISPER_MAX_SLICES=200
# HF_TOKEN=your_huggingface_token
MAX_UPLOAD_MB=100
TEMP_DIR=./data/temp
LOG_LEVEL=INFO
API_HOST=127.0.0.1
API_PORT=8000
# Streamlit → API URL override (set to ALB URL in AWS, e.g. http://rre-dev-xxxxx.us-east-2.elb.amazonaws.com)
RRE_API_BASE_URL=
STREAMLIT_PORT=8501
DEFAULT_OLLAMA_MODEL=
# Set true only for models/workflows that should use Ollama "thinking" mode.
OLLAMA_THINK=false
OLLAMA_MODULE_JSON_FORMAT=true
OLLAMA_NUM_PREDICT=8192
DATABASE_URL=sqlite:///./data/rre.db
# PostgreSQL example (set ALEMBIC_AUTO_UPGRADE=true for production):
# DATABASE_URL=postgresql+psycopg://user:pass@localhost:5432/rre
DATABASE_POOL_SIZE=5
ALEMBIC_AUTO_UPGRADE=false
API_KEY=
LOG_JSON=false
# None/unset = auto (on for Bedrock / non-SQLite). Set true|false to force.
# LOG_REDACT=true
# Delete transcripts (and cascaded runs) older than N days on API startup. Unset = keep forever.
# TRANSCRIPT_RETENTION_DAYS=90
WORKFLOW_BACKGROUND_DEFAULT=false
EVIDENCE_PROMPT_MAX_QUOTES=120
EVIDENCE_PROMPT_HEAD_QUOTES=80
EVIDENCE_PROMPT_TAIL_QUOTES=40
