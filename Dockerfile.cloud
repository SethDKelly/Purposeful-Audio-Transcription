# RRE API — cloud slim image (Bedrock + Amazon Transcribe; no torch/Whisper).
FROM python:3.12-slim-bookworm

RUN apt-get update \
    && apt-get install -y --no-install-recommends curl \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY pyproject.toml README.md ./
COPY backend ./backend
COPY config ./config
COPY alembic ./alembic
COPY alembic.ini ./

RUN pip install --no-cache-dir --upgrade pip \
    && pip install --no-cache-dir -e .

ENV API_HOST=0.0.0.0 \
    API_PORT=8000 \
    LOG_JSON=true \
    PYTHONUNBUFFERED=1 \
    LLM_PROVIDER=bedrock \
    TRANSCRIPTION_PROVIDER=transcribe \
    DIARIZATION_ENABLED=false \
    ALEMBIC_AUTO_UPGRADE=true \
    UVICORN_WORKERS=2 \
    RRE_PROCESS=api

EXPOSE 8000

# Looser than default so brief Bedrock load spikes don't flip the Docker HEALTHCHECK.
# Worker process has no HTTP port — HEALTHCHECK only applies when RRE_PROCESS=api.
HEALTHCHECK --interval=30s --timeout=5s --start-period=90s --retries=5 \
    CMD sh -c 'if [ "${RRE_PROCESS:-api}" = "worker" ]; then exit 0; fi; curl -f "http://127.0.0.1:8000/api/live" || exit 1'

# RRE_PROCESS=api (default) or worker. Same image for API and dedicated worker tasks.
CMD ["sh", "-c", "if [ \"${RRE_PROCESS:-api}\" = \"worker\" ]; then exec python -m backend.worker; else exec uvicorn backend.main:app --host 0.0.0.0 --port 8000 --workers ${UVICORN_WORKERS:-2}; fi"]
